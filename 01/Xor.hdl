// File name: projects/01/Xor.hdl

/**
 * Exclusive-or gate:
 * out = not (a == b)
 */

CHIP Xor {
    IN a, b;
    OUT out;

    PARTS:
    // Put your code here:
    Not(in= a, out= nota);
    Not(in= b, out= notb);
    And(a= a, b= notb, out= outAnd1);
    And(a= nota, b= b, out= outAnd2);
    Or(a= outAnd1, b= outAnd2, out= out);

}